   "source": [
    "import torch\n",
    "v1 = torch.arange(4)\n",
    "v2 = torch.arange(4, 8)\n",
    "print(v1)\n",
    "print(v2)\n",
    "print(torch.outer(v1, v2))\n",
    "print(v1[:, None])\n",
    "print(v2[None, :])"
   ]
